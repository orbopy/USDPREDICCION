# ─────────────────────────────────────────
# USDPREDICCION — Variables de entorno
# Copiar este archivo a .env y completar
# ─────────────────────────────────────────

# Redis
REDIS_URL=redis://localhost:6379

# LLM — OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=google/gemini-2.0-flash-exp:free

# Noticias — GNews (https://gnews.io) — plan free = 100 req/día
GNEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ML Engine
ML_PORT=8001
ML_SERVICE_URL=http://localhost:8001

# API Gateway
API_PORT=3001

# Pairs a monitorear (separados por coma)
TRADING_PAIRS=USD/ARS,USD/BRL,BRL/PYG

# Predicción: horizonte en minutos
HORIZON_MINUTES=15

# Solo alertar cuando confianza >= umbral (0.0 a 1.0)
CONFIDENCE_THRESHOLD=0.65
ALERT_ONLY_HIGH=false

# Webhook para alertas (opcional — Discord, n8n, etc.)
ALERT_WEBHOOK_URL=

# ─────────────────────────────────────────
# TELEGRAM BOT
# ─────────────────────────────────────────
# Token del bot (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=8711444066:AAExkhwZBq7zSDq-cAb88B342nTedJKpm6Q

# Confianza mínima para enviar alerta por Telegram (0.0 a 1.0)
# Recomendado: 0.70 — solo señales fuertes
TELEGRAM_ALERT_CONFIDENCE=0.70

# Hora del informe diario automático (formato 24h, zona ARG)
DAILY_REPORT_HOUR=20

# Logging
LOG_LEVEL=info
